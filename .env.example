# .env.example — copy ke .env dan isi nilainya

# ─── Database ─────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Untuk local: install PostgreSQL, buat database "resto_app"
# Untuk Railway: copy dari dashboard Railway
DATABASE_URL="postgresql://postgres:password@localhost:5432/resto_app"

# ─── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Frontend URL (untuk CORS) — sesuaikan saat production
FRONTEND_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────
# Ganti dengan string random yang panjang dan aman
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_string_random_yang_sangat_panjang_dan_aman
JWT_EXPIRES_IN=7d

# ─── Midtrans ─────────────────────────────────────────────────
# Daftar di: https://dashboard.sandbox.midtrans.com
# Settings > Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ─── Email (Nodemailer) ────────────────────────────────────────
# Opsi 1: Gmail (aktifkan "App Password" di Google Account)
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=emailkamu@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx   # App Password dari Google (bukan password biasa)
EMAIL_FROM="Warung Barokah <emailkamu@gmail.com>"

# Email admin yang terima notifikasi order baru
ADMIN_EMAIL=admin@warungbarokah.com
